# Core environment variables
MONGODB_URI=
MONGODB_DB=nyaysaathi
DJANGO_SECRET_KEY=
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com,.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Security and CSRF
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXP_HOURS=24

# Runtime
DJANGO_SETTINGS_MODULE=nyaysaathi_project.settings
SEARCH_MODE=semantic
DEFAULT_LANGUAGE=en
LOG_LEVEL=INFO

# Throttling and caching
THROTTLE_ANON_RATE=300/day
THROTTLE_CLASSIFY_RATE=20/min
DJANGO_CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache
DJANGO_CACHE_LOCATION=nyaysaathi-local-cache
DJANGO_CACHE_TIMEOUT=300

# Mongo connection resilience
MONGO_RETRY_COUNT=3
MONGO_RETRY_BACKOFF_SECONDS=1.0
MONGO_FAILURE_COOLDOWN_SECONDS=5
MONGO_SERVER_SELECTION_TIMEOUT_MS=30000
MONGO_CONNECT_TIMEOUT_MS=30000
MONGO_SOCKET_TIMEOUT_MS=30000
MONGO_MAX_POOL_SIZE=20
MONGO_MIN_POOL_SIZE=0

# AI and embeddings
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
SEMANTIC_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_CACHE_TTL_SECONDS=900
EMBEDDING_BATCH_SIZE=64
