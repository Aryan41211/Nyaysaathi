{
  "version": 2,
  "installCommand": "cd nyaysaathi/frontend && npm install",
  "buildCommand": "cd nyaysaathi/frontend && npm run build",
  "outputDirectory": "nyaysaathi/frontend/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://nyaysaathi-backend.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}