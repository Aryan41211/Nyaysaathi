# NyaySaathi Backend – Environment Variables
# Copy this file to .env and fill in your values

# Django
DJANGO_SECRET_KEY=replace-with-50-char-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=nyaysaathi

# CORS – add your Vercel frontend URL in production
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Search mode: "keyword" (default, fast) or "semantic" (better, needs more RAM)
SEARCH_MODE=keyword

# Anthropic Claude API – for NLP query understanding (optional but recommended)
# Without this key, the system uses a rule-based fallback (still works, less accurate for Hindi/Marathi)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here
