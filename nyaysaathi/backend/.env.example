# NyaySaathi Backend – Environment Variables
# Copy this file to .env and fill in your values

# Django
DJANGO_SECRET_KEY=replace-with-50-char-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=nyaysaathi

# CORS – add your Vercel frontend URL in production
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOWED_ORIGIN_REGEXES=
CSRF_TRUSTED_ORIGINS=

# Search mode: "keyword" (fast) or "semantic" (default, better quality)
SEARCH_MODE=semantic
DEFAULT_LANGUAGE=en

# OpenAI API key – used for NLP understanding, multilingual translation and embeddings.
# Without this key, the system falls back to non-AI paths where possible.
OPENAI_API_KEY=sk-your-openai-key-here
