# NyaySaathi Backend – Environment Variables
# Copy this file to .env and fill in your values

# Django
DJANGO_SECRET_KEY=replace-with-50-char-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=nyaysaathi

# CORS – add your Vercel frontend URL in production
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOWED_ORIGIN_REGEXES=
CSRF_TRUSTED_ORIGINS=

# Search mode: "keyword" (fast) or "semantic" (default, better quality)
SEARCH_MODE=semantic
DEFAULT_LANGUAGE=en

# Auth/JWT
JWT_SECRET=replace-with-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXP_HOURS=24

# API throttling
THROTTLE_ANON_RATE=300/day
THROTTLE_CLASSIFY_RATE=20/min

# Mongo reliability
MONGO_RETRY_COUNT=3
MONGO_RETRY_BACKOFF_SECONDS=0.25
MONGO_SERVER_SELECTION_TIMEOUT_MS=1000
MONGO_CONNECT_TIMEOUT_MS=1000
MONGO_SOCKET_TIMEOUT_MS=1000
MONGO_MAX_POOL_SIZE=20
MONGO_MIN_POOL_SIZE=0
