# NyaySaathi Frontend Environment Variables
# Copy to .env and fill in

# In dev: Vite proxies /api -> localhost:8000
# In production: set to your Render backend host (with or without /api)
VITE_API_URL=https://nyaysaathi-backend.onrender.com

# Optional: secondary backend URL used only when primary API routing fails.
VITE_FALLBACK_API_URL=https://nyaysaathi-backend.onrender.com/api
