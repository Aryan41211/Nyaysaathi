# Django Core Settings
DJANGO_SECRET_KEY=your-super-secret-key-generate-with-python-c-secrets-token-urlsafe-50
DEBUG=False
DJANGO_ENV=production
ALLOWED_HOSTS=yourdomain.com,api.yourdomain.com

# Security Settings
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app,https://your-custom-domain.com
CSRF_TRUSTED_ORIGINS=https://your-frontend-domain.vercel.app,https://your-custom-domain.com

# Database (PostgreSQL for production)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# MongoDB (for legal cases data)
MONGODB_URI=mongodb://username:password@host:27017
MONGODB_DB=nyaysaathi

# AI/ML Settings
OPENAI_API_KEY=your-openai-api-key
MODEL_MODE=hybrid

# Email Settings (for production)
EMAIL_HOST=smtp.your-email-provider.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@domain.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Rate Limiting (optional - defaults provided)
RATE_LIMIT_ENABLED=True

# Logging
LOG_LEVEL=INFO

# Frontend URL (for CORS and CSP)
FRONTEND_URL=https://your-frontend-domain.vercel.app